OPENAI_RECEIPT_MODEL=gpt-4o
# Encrypts the shared club credit card at rest (AES-256-GCM). Must be the
# base64 encoding of 32 random bytes, e.g. `openssl rand -base64 32`.
CARD_ENCRYPTION_KEY=
